<?xml version="1.0"?>
<ruleset name="php-big-integer">
    <description>Code style rules for php-big-integer.</description>

    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg value="sp"/>
    <arg name="colors"/>

    <file>src</file>
    <file>tests</file>
    <file>console</file>

    <exclude-pattern>vendor/*</exclude-pattern>

    <rule ref="PSR12"/>
</ruleset>
